# Required — Claude Agent SDK credentials
ANTHROPIC_API_KEY=

# Budget caps (USD). Orchestrator aborts a stage / run when exceeded.
DF_BUDGET_USD_PER_RUN=20
DF_BUDGET_USD_PER_STAGE=5

# Wall-clock caps (seconds)
DF_TIMEOUT_SEC_PER_RUN=3600
DF_TIMEOUT_SEC_PER_STAGE=600

# Concurrency for the worker poll loop
DF_MAX_CONCURRENT_RUNS=2

# Review loop
DF_MAX_REVIEW_ITERS=3

# Optional fourth critic: /codex:adversarial-review (from the Codex
# Claude Code plugin). Values: auto (default — run if plugin + codex CLI
# detected), on (require, fail the review stage otherwise), off (never).
DF_ADVERSARIAL_REVIEW=auto

# Absolute path to codex-companion.mjs. Leave blank to auto-discover
# the highest-version install under ~/.claude/plugins/cache/openai-codex/.
DF_CODEX_COMPANION=

# Absolute path to this checkout (defaults to cwd of the worker process)
DF_ROOT=

# Model override (optional). If unset, the SDK picks its default.
DF_MODEL=
