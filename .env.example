# Auth is handled by the Claude Code CLI (`claude login`) and, for the
# optional adversarial critic, the Codex CLI (`codex login`). mill scrubs
# ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN from the env it passes to
# `claude` so subscription billing is never silently bypassed.

# Wall-clock caps (seconds). MILL_TIMEOUT_SEC_PER_STAGE is the default.
# Stages with genuinely heavier workloads override via their own vars —
# implement gets 2h because a from-scratch TDD build of a real app is
# 100+ tool calls; verify gets 30 min because end-to-end checks take a
# while. The global MILL_TIMEOUT_SEC_PER_RUN caps everything.
MILL_TIMEOUT_SEC_PER_RUN=14400
MILL_TIMEOUT_SEC_PER_STAGE=600
MILL_TIMEOUT_SEC_IMPLEMENT=7200
MILL_TIMEOUT_SEC_VERIFY=1800

# Concurrency for the worker poll loop
MILL_MAX_CONCURRENT_RUNS=2

# Review loop
MILL_MAX_REVIEW_ITERS=3

# Optional fourth critic: /codex:adversarial-review (from the Codex
# Claude Code plugin). Values: auto (default — run if plugin + codex CLI
# detected), on (require, fail the review stage otherwise), off (never).
MILL_ADVERSARIAL_REVIEW=auto

# Team-mode review. When enabled, the three LLM critics
# (security/correctness/ux) run inside one `claude` subprocess as an
# agent team (TeamCreate + Agent(team_name=...)) so they can cross-
# reference each other's findings mid-review via SendMessage. Values:
# auto (default — try team mode, fall back to subprocess-per-critic on
# any failure), on (require team mode, fail the review stage if it
# errors), off (always use the subprocess-per-critic path). tests and
# adversarial critics always run as their own subprocesses regardless.
MILL_AGENT_TEAMS=auto

# Absolute path to codex-companion.mjs. Leave blank to auto-discover
# the highest-version install under ~/.claude/plugins/cache/openai-codex/.
MILL_CODEX_COMPANION=

# Absolute path to this checkout (defaults to cwd of the worker process)
MILL_ROOT=

# Model override (optional). If unset, the SDK picks its default.
MILL_MODEL=

# New-mode workdir promotion. After a clean delivery (verify pass + no
# unresolved HIGH+ findings) in `mill new` runs, copy the workdir
# contents up into the project root so the result lands "right there"
# instead of buried under `.mill/runs/<id>/workdir/`.
#  - auto (default): copy when the parent root is empty save for
#    `.git`, `.gitignore`, `.mill`. Skip otherwise (don't clobber).
#  - on:  copy unconditionally on a clean delivery.
#  - off: never copy. Workdir stays in `.mill/`.
# Edit-mode runs are unaffected — they already commit on a fresh
# `mill/run-<id>` branch via `git worktree add`.
MILL_PROMOTE_NEW_WORKDIR=auto

# Path to a JSON file whose `mcpServers` field is loaded as user-level
# MCPs (Stitch, Playwright, etc.). Default: ~/.claude/settings.json,
# then ~/.claude.json. Only the MCP servers are consumed — hooks in
# that file do NOT fire. Consulted only when a stage explicitly opts
# into the MCPs-without-hooks path; with the default MILL_USER_HOOKS=on
# below, user MCPs already arrive via --setting-sources user.
MILL_USER_MCP_CONFIG=

# In-run `claude` subprocesses load `--setting-sources user,project` by
# default, so user-level skills (e.g. a `commit` skill that suppresses
# the Co-Authored-By Claude trailer) and hooks (Stop, PostToolUse, etc.)
# fire inside mill stages just like they would in a normal Claude Code
# session. Set to `off` to revert to project-only isolation — useful in
# CI or shared environments where user hooks would be inappropriate.
MILL_USER_HOOKS=on
